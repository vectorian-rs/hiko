(* Fetch a URL and print status, headers, and body *)

val (status, headers, body) = http_get "https://www.google.com/"

val _ = println ("Status: " ^ int_to_string status)

fun print_headers hs = case hs of
      [] => ()
    | (k, v) :: rest => let
        val _ = println ("  " ^ k ^ ": " ^ v)
      in
        print_headers rest
      end

val _ = println "Headers:"

val _ = print_headers headers
(* 
  val _ = println "Body:" 
  val _ = println body 
*)
