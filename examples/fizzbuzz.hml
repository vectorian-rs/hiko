fun fizzbuzz n =
  if n mod 15 = 0 then "FizzBuzz"
  else if n mod 3 = 0 then "Fizz"
  else if n mod 5 = 0 then "Buzz"
  else int_to_string n

fun loop i max =
  if i > max then ()
  else let val _ = println ((int_to_string i) ^ " : " ^ (fizzbuzz i))
       in loop (i + 1) max end

val _ = loop 1 100
