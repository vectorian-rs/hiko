import Std.List

val nums = [1, 2, 3, 4, 5]
val sum = List.foldl (fn (acc, x) => acc + x) 0 nums
val product = List.foldr (fn (x, acc) => x * acc) 1 nums
val len = List.length nums
val rev = List.reverse nums
val joined = List.append [1, 2] [3, 4, 5]

val _ = println (int_to_string sum)
val _ = println (int_to_string product)
val _ = println (int_to_string len)
val _ = println (int_to_string (List.nth rev 0))
val _ = println (int_to_string (List.last nums))
val _ = println (int_to_string (List.length (List.take 3 nums)))
val _ = println (int_to_string (List.nth (List.drop 2 nums) 0))
val _ = println (int_to_string (List.length joined))
val _ = println (if List.all (fn x => x > 0) nums then "all positive" else "not all")
val _ = println (if List.any (fn x => x > 4) nums then "found >4" else "none >4")
