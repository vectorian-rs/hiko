(* tool: edit
 * description: Edit a file using hashline anchors. Verifies content hashes before applying. Format per edit line: ACTION LINE:HASH CONTENT. Actions: R (replace), I (insert after), D (delete).
 * param path: string - File path to edit
 * param edits: string - Newline-separated edit operations
 *)

val input = read_stdin ()
val path = json_get (input, "path")
val edits_raw = json_get (input, "edits")
val _ = print (edit_file_tagged (path, edits_raw))
