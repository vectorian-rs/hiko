(* tool: find
 * description: Find files matching a glob pattern
 * param pattern: string - Glob pattern (e.g. src/**/*.rs)
 *)

use "../libraries/Std-v0.1.0/modules/List.hml"

val input = read_stdin ()
val pattern = json_get (input, "pattern")
val files = glob pattern
val _ = List.map println files
