(* Ackermann function — from Manticore seq-ack benchmark
 * Input: (3, 11) => 16381
 *)

fun ack (m, n) =
  if m = 0 then n + 1
  else if n = 0 then ack (m - 1, 1)
  else ack (m - 1, ack (m, n - 1))

val result = ack (3, 9)
val _ = assert_eq (result, 4093, "ack(3,9)")
val _ = println ("ack(3,9) = " ^ int_to_string result)
