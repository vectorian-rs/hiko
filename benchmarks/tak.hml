(* Takeuchi function — from Manticore seq-tak benchmark
 * Input: (40, 20, 11) => 12
 *)

fun tak (x, y, z) =
  if y < x
  then tak (tak (x - 1, y, z), tak (y - 1, z, x), tak (z - 1, x, y))
  else z

val result = tak (24, 16, 8)
val _ = assert_eq (result, 9, "tak(24,16,8)")
val _ = println ("tak(24,16,8) = " ^ int_to_string result)
