(* Option type and operations *)

datatype 'a option = None | Some of 'a

fun is_some opt =
  case opt of
    Some _ => true
  | None   => false

fun is_none opt =
  case opt of
    None   => true
  | Some _ => false

fun map_option f opt =
  case opt of
    None   => None
  | Some x => Some (f x)

fun get_or opt default =
  case opt of
    None   => default
  | Some x => x

fun flat_map_option f opt =
  case opt of
    None   => None
  | Some x => f x
