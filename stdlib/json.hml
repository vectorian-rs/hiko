(* JSON data type for structured JSON handling.
 * Constructor tags are fixed (0-6) and must match
 * the json_parse builtin in builtins.rs.
 *)

datatype json = JNull
              | JBool of bool
              | JInt of int
              | JFloat of float
              | JStr of string
              | JArray of json list
              | JObject of (string * json) list
