val fuel_status =
  Result.fold
    (fn _ => 0)
    (fn err =>
      if string_contains (Fiber.render_error err, "fuel exhausted") then 1 else 0)
    (Fiber.join child)

val _ = assert_eq (fuel_status, 1, "fuel exhausted")
val _ = println "fiber fuel tests passed"
