(* Tests for Std-v0.1.0/modules/Hashline.hml *)

use "../../libraries/Std-v0.1.0/modules/Hashline.hml"

(* Set up a test file *)
val test_path = ".test_hashline_tmp.txt"
val _ = write_file (test_path, "alpha\nbeta\ngamma\n")

(* Test read_all returns tagged lines *)
val tagged = Hashline.run (fn () => Hashline.read_all test_path)
val lines = split (tagged, "\n")

(* Each non-empty line should match LINE:HASH\tCONTENT *)
val first = case lines of x :: _ => x | [] => panic "empty"
val _ = assert_eq (regex_match (first, "^1:[0-9a-zA-Z]{2}\talpha$"), true, "read_all line format")

(* Test read with offset and limit *)
val partial = Hashline.run (fn () => Hashline.read test_path 1 1)
val _ = assert_eq (regex_match (partial, "^2:[0-9a-zA-Z]{2}\tbeta\n$"), true, "read offset/limit")

(* Test edit: replace beta with BETA *)
val beta_line = partial
val anchor = case split (beta_line, "\t") of
    anchor :: _ => trim anchor
  | [] => panic "no anchor"

val edit_cmd = "R " ^ anchor ^ " BETA"
val result = Hashline.run (fn () => Hashline.edit test_path edit_cmd)
val _ = assert_eq (regex_match (result, "Applied 1 edit"), true, "edit applied")

(* Verify the edit took effect *)
val after = read_file test_path
val _ = assert_eq (after, "alpha\nBETA\ngamma\n", "edit content")

(* Test staleness rejection: use the old anchor again *)
val stale_result = Hashline.run (fn () => Hashline.edit test_path edit_cmd)
val _ = assert_eq (regex_match (stale_result, "REJECTED"), true, "stale hash rejected")

(* Clean up *)
val _ = remove_file test_path

val _ = println "hashline tests passed"
