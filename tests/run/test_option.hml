(* Tests for Std-v0.1.0/modules/Option.hml *)

use "../../libraries/Std-v0.1.0/modules/Option.hml"

val _ = assert (Option.is_some (Option.Some 1), "is_some Some")
val _ = assert (Option.is_none Option.None, "is_none None")
val _ = assert (not (Option.is_some Option.None), "not is_some None")

val _ = assert_eq (Option.get_or (Option.Some 42) 0, 42, "get_or Some")
val _ = assert_eq (Option.get_or Option.None 99, 99, "get_or None")

val _ = assert_eq (Option.get_or (Option.map_option (fn x => x + 1) (Option.Some 41)) 0, 42, "map_option Some")
val _ = assert (Option.is_none (Option.map_option (fn x => x + 1) Option.None), "map_option None")

val _ = println "option tests passed"
