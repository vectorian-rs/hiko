(* Tests for Std-v0.1.0/modules/List.hml *)

use "../../libraries/Std-v0.1.0/modules/List.hml"

val _ = assert_eq (List.length [], 0, "length empty")
val _ = assert_eq (List.length [1, 2, 3], 3, "length 3")

val _ = assert_eq (List.nth [10, 20, 30] 0, 10, "nth 0")
val _ = assert_eq (List.nth [10, 20, 30] 2, 30, "nth 2")

val _ = assert_eq (List.last [1, 2, 3], 3, "last")

val _ = assert_eq (List.length (List.map (fn x => x * 2) [1, 2, 3]), 3, "map length")
val _ = assert_eq (List.nth (List.map (fn x => x * 2) [1, 2, 3]) 0, 2, "map head")

val _ = assert_eq (List.length (List.filter (fn x => x > 2) [1, 2, 3, 4, 5]), 3, "filter")

val _ = assert_eq (List.foldl (fn (acc, x) => acc + x) 0 [1, 2, 3], 6, "foldl sum")
val _ = assert_eq (List.foldr (fn (x, acc) => x * acc) 1 [1, 2, 3, 4], 24, "foldr product")

val _ = assert_eq (List.nth (List.reverse [1, 2, 3]) 0, 3, "reverse head")
val _ = assert_eq (List.length (List.reverse [1, 2, 3]), 3, "reverse length")

val _ = assert_eq (List.length (List.append [1, 2] [3, 4, 5]), 5, "append length")
val _ = assert_eq (List.nth (List.append [1, 2] [3, 4, 5]) 2, 3, "append middle")

val _ = assert_eq (List.length (List.take 3 [1, 2, 3, 4, 5]), 3, "take 3")
val _ = assert_eq (List.nth (List.drop 2 [1, 2, 3, 4, 5]) 0, 3, "drop 2")

val _ = assert (List.all (fn x => x > 0) [1, 2, 3], "all positive")
val _ = assert (List.any (fn x => x > 4) [1, 2, 3, 4, 5], "any > 4")
val _ = assert (not (List.any (fn x => x > 10) [1, 2, 3]), "none > 10")

val _ = println "list tests passed"
