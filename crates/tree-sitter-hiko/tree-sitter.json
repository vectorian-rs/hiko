{
  "grammars": [
    {
      "name": "hiko",
      "camelcase": "Hiko",
      "scope": "source.hiko",
      "path": ".",
      "file-types": [
        "hml"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^hiko$"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Hiko language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-hiko"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
